{
  "name": "nireco-comet-integration-contract",
  "contractVersion": "0.4-preview.1",
  "status": "preview",
  "releasedAt": "2026-07-16",
  "normativeSources": {
    "spec": {
      "path": "../../NIRECO_AGENT_NATIVE_EDITOR_DEVELOPMENT_SPEC.md",
      "version": "0.4.2"
    },
    "roadmap": {
      "path": "../../NIRECO_COMET_ROADMAP.md",
      "version": "0.1.1"
    },
    "engineeringStandard": {
      "path": "../../NIRECO_COMET_ENGINEERING_CODING_STANDARD.md",
      "version": "0.1.1"
    }
  },
  "schemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "protocolVersions": {
    "documentFormatVersion": "1.0.0-preview.1",
    "manuscriptSchemaVersion": "1.0.0-preview.1",
    "transactionProtocolVersion": "0.4-preview.1",
    "proposalProtocolVersion": "0.4-preview.1",
    "semanticEditProtocolVersion": "0.4-preview.1",
    "semanticDiffProtocolVersion": "0.4-preview.1",
    "traceProtocolVersion": "0.4-preview.1"
  },
  "wireFormat": {
    "fieldNaming": "camelCase",
    "nodeDiscriminator": "type",
    "semanticEditDiscriminator": "kind",
    "unknownFieldPolicy": "reject",
    "defaultAdditionalProperties": false,
    "positionEncoding": "utf-16-code-unit",
    "timestampEncoding": "rfc3339-utc",
    "hashEncoding": "sha256:<lowercase-hex>"
  },
  "canonicalization": {
    "profile": "nireco-canonical-json-0.1",
    "style": "RFC 8785",
    "objectKeyOrder": "unicode-code-point",
    "arrayOrder": "preserve",
    "unicodeNormalization": "none",
    "omitUndefined": true,
    "finiteNumbersOnly": true,
    "hashAlgorithm": "sha256"
  },
  "identity": {
    "opaqueIds": true,
    "idRepresentationFrozen": false,
    "fixtureIdStyle": "readable-opaque-test-values",
    "resourceUriWireProfile": {
      "characterSet": "ascii-visible",
      "unicodeEncoding": "utf8-percent-encoding",
      "percentHexCase": "upper"
    },
    "documentAddress": ["uri", "revisionId"],
    "mutableDocumentAddress": ["uri", "baseRevisionId"],
    "logicalUriProfile": {
      "schemes": ["nireco", "comet"],
      "lowercaseScheme": true,
      "lowercaseHost": true,
      "userinfoAllowed": false,
      "queryAllowed": false,
      "fragmentAllowed": false,
      "portAllowed": false,
      "minimumPathSegments": 2,
      "trailingSlashAllowed": false,
      "pathCase": "preserve"
    }
  },
  "manuscriptVocabulary": {
    "schemaId": "nireco.manuscript",
    "metadataFields": ["title", "authors", "abstract", "keywords"],
    "nodeTypes": [
      "manuscript",
      "frontMatter",
      "body",
      "section",
      "heading",
      "paragraph",
      "text",
      "citation",
      "crossReference",
      "inlineEquation",
      "displayEquation",
      "figure",
      "figureAsset",
      "figureCaption",
      "table",
      "tableRow",
      "tableCell",
      "tableCaption",
      "list",
      "listItem",
      "blockQuote",
      "codeBlock",
      "footnote",
      "footnoteReference",
      "hardBreak",
      "horizontalRule",
      "bibliographyPlaceholder"
    ]
  },
  "schemas": [
    {
      "name": "common",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/common.schema.json",
      "path": "schemas/common.schema.json",
      "role": "shared identity, hash, timestamp, actor, and JSON scalar definitions"
    },
    {
      "name": "resource-ref",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/resource-ref.schema.json",
      "path": "schemas/resource-ref.schema.json",
      "role": "canonical URI and revision-bound resource references"
    },
    {
      "name": "position-anchor",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/position-anchor.schema.json",
      "path": "schemas/position-anchor.schema.json",
      "role": "UTF-16 semantic positions, ranges, targets, and persistent anchors"
    },
    {
      "name": "diagnostic",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/diagnostic.schema.json",
      "path": "schemas/diagnostic.schema.json",
      "role": "revision-bound diagnostics"
    },
    {
      "name": "manuscript",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/manuscript.schema.json",
      "path": "schemas/manuscript.schema.json",
      "role": "canonical immutable manuscript snapshot"
    },
    {
      "name": "operation",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/operation.schema.json",
      "path": "schemas/operation.schema.json",
      "role": "deterministic internal operation algebra"
    },
    {
      "name": "transaction",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/transaction.schema.json",
      "path": "schemas/transaction.schema.json",
      "role": "atomic transaction protocol"
    },
    {
      "name": "revision",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/revision.schema.json",
      "path": "schemas/revision.schema.json",
      "role": "single-parent immutable revision protocol"
    },
    {
      "name": "semantic-edit",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/semantic-edit.schema.json",
      "path": "schemas/semantic-edit.schema.json",
      "role": "high-level proposal-only Agent edit protocol"
    },
    {
      "name": "proposal",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/proposal.schema.json",
      "path": "schemas/proposal.schema.json",
      "role": "proposal state and optimistic proposal revision protocol"
    },
    {
      "name": "semantic-diff",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/semantic-diff.schema.json",
      "path": "schemas/semantic-diff.schema.json",
      "role": "deterministic proposal review groups and dependencies"
    },
    {
      "name": "integration",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/integration.schema.json",
      "path": "schemas/integration.schema.json",
      "role": "trusted adapter handshake, session, scope, limits, and Gate 0 service messages"
    },
    {
      "name": "error",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/error.schema.json",
      "path": "schemas/error.schema.json",
      "role": "typed contract error envelope"
    },
    {
      "name": "trace",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/trace.schema.json",
      "path": "schemas/trace.schema.json",
      "role": "low-sensitivity integration trace"
    },
    {
      "name": "golden-fixture",
      "id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/golden-fixture.schema.json",
      "path": "schemas/golden-fixture.schema.json",
      "role": "self-describing golden fixture envelope"
    }
  ],
  "catalogs": [
    {
      "name": "error-codes",
      "path": "error-codes.json",
      "schemaId": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/error.schema.json"
    },
    {
      "name": "capability-matrix",
      "path": "capability-matrix.json"
    },
    {
      "name": "semantic-edits",
      "path": "semantic-edits.json",
      "schemaId": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/semantic-edit.schema.json"
    }
  ],
  "fixtures": [
    {
