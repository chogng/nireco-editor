  "sampleTraces": [
    {
      "name": "read-only-session",
      "path": "sample-traces/read-only-session.json",
      "schemaId": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/trace.schema.json"
    },
    {
      "name": "draft-proposal",
      "path": "sample-traces/draft-proposal.json",
      "schemaId": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/trace.schema.json"
    }
  ],
  "mockService": {
    "packageExport": "@comet-internal/nireco-editor/comet-internal",
    "className": "MockCometIntegrationService",
    "documentationPath": "mock-service/README.md",
    "supportedOperations": [
      "integration.handshake",
      "integration.open_session",
      "document.get_snapshot",
      "proposal.create",
      "proposal.stage_semantic_edits"
    ]
  },
  "conformanceRunner": {
    "command": "pnpm contract:conformance",
    "documentationPath": "conformance-runner/README.md",
    "sourcePath": "../../tests/conformance"
  },
  "agentSafety": {
    "onlyWritePath": "semantic-edit-to-proposal",
    "mainlineCommitAllowed": false,
    "rawTransactionAllowed": false,
    "reviewAcceptanceAllowed": false,
    "trustedEnvelopeFieldsModelControlled": false
  },
  "gate0CompilerDecisionBlockers": [
    {
      "semanticEditKind": "update-metadata",
      "status": "lowering-deferred",
      "reason": "The specification defines UpdateMetadataEdit but does not define a document-metadata Operation, and canonical metadata is not stored in manuscript-root attrs.",
      "behaviorUntilResolved": "Do not advertise update-metadata in supportedSemanticEdits; Proposal validation and compilation return SEMANTIC_EDIT_UNSUPPORTED."
    }
  ],
  "codeGeneration": {
    "sourceOfTruth": "schemas",
    "generatedTypesIncluded": true,
    "outputPath": "generated-types/",
    "generateCommand": "pnpm contract:generate",
    "driftCheckCommand": "pnpm contract:check",
    "policy": "Generated TypeScript or Rust types must be regenerated from the manifest schemas and must never be hand-edited."
  },
  "compatibility": {
    "majorMismatchPolicy": "reject",
    "requiredCapabilityPolicy": "all-required-must-be-confirmed",
    "unknownFieldPolicy": "reject",
    "unsafeSemanticEditFallbackAllowed": false
  }
}
