{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.nireco.dev/comet-integration/0.4-preview.2/schemas/common.schema.json",
  "title": "Nireco–Comet Common Contract Types",
  "description": "Closed, transport-neutral scalar and identity definitions shared by the Gate 0 contract.",
  "$defs": {
    "OpaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$",
      "description": "External or integration-owned opaque identity. Nireco-allocated production identities use AllocatedId instead."
    },
    "AllocatedId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "Canonical lowercase RFC 9562 UUIDv7 allocated by a trusted Nireco boundary before reducer entry."
    },
    "DerivedId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-8[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "Canonical lowercase RFC 9562 UUIDv8 deterministically derived from a frozen domain-separated SHA-256 preimage."
    },
    "WorkspaceId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "RevisionId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "TransactionId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "OperationId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "NodeId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "EntityId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "ProposalId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "ProposalChangeGroupId": {
      "$ref": "#/$defs/DerivedId"
    },
    "SessionId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "DebugId": {
      "$ref": "#/$defs/AllocatedId"
    },
    "RequestId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "TraceId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "TaskId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "ToolInvocationId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "CapabilityGrantId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "PolicySnapshotId": {
      "$ref": "#/$defs/OpaqueId"
    },
    "ClientRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$",
      "description": "Untrusted, request-local correlation key. It is never a trusted Nireco identity."
    },
    "ContentHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "HashDomain": {
      "enum": [
        "nireco.academic-entity.v1",
        "nireco.document-content.v1",
        "nireco.governance-manifest.v1",
        "nireco.node.v1",
        "nireco.proposal-change-group.v1",
        "nireco.semantic-diff.v1",
        "nireco.transaction.v1"
      ]
    },
    "HashConformanceVector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "domain",
        "payloadSchemaId",
        "payload",
        "canonicalJson",
        "preimageUtf8Hex",
        "expectedHash"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "domain": {
          "$ref": "#/$defs/HashDomain"
        },
        "payloadSchemaId": {
          "type": "string",
          "format": "uri"
        },
        "payload": {
          "$ref": "#/$defs/JsonValue"
        },
        "canonicalJson": {
          "type": "string"
        },
        "preimageUtf8Hex": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{2})+$"
        },
        "expectedHash": {
          "$ref": "#/$defs/ContentHash"
        }
      }
    },
    "HashConformanceVectorSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "preimageFormula", "vectors"],
      "properties": {
        "profile": {
          "const": "nireco-hash-preimage-1"
        },
        "preimageFormula": {
          "const": "UTF8(NIRECO\\0HASH\\0V1\\0 + domain + \\0 + canonicalJson(payload))"
        },
        "vectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/HashConformanceVector"
          }
        }
      }
    },
    "GovernanceManifestHashPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engineeringStandardVersion", "files"],
      "properties": {
        "engineeringStandardVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GovernanceManifestFileHash"
          }
        }
      }
    },
    "GovernanceManifestFileHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "rawSha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "rawSha256": {
          "$ref": "#/$defs/ContentHash"
        }
      }
    },
    "Rfc3339Timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "Utf16Offset": {
      "type": "integer",
      "minimum": 0,
      "description": "Offset measured in UTF-16 code units. A service must additionally reject a value inside a surrogate pair."
    },
    "ActorRef": {
      "oneOf": [
        {
          "$ref": "#/$defs/HumanActorRef"
        },
        {
          "$ref": "#/$defs/CometAgentActorRef"
        },
        {
          "$ref": "#/$defs/ProductControllerActorRef"
        },
        {
          "$ref": "#/$defs/SystemActorRef"
        }
      ]
    },
    "HumanActorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "const": "human"
        },
        "id": {
          "$ref": "#/$defs/OpaqueId"
        }
      }
    },
    "CometAgentActorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "workflowId"],
      "properties": {
        "type": {
          "const": "comet-agent"
        },
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "workflowId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "modelRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "ProductControllerActorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "const": "product-controller"
        },
        "id": {
          "$ref": "#/$defs/OpaqueId"
        }
      }
    },
    "SystemActorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "role"],
      "properties": {
        "type": {
          "const": "system"
        },
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "role": {
          "enum": ["importer", "migration", "validator", "recovery"]
        }
      }
    },
    "JsonValue": {
      "description": "A JSON value used only at explicitly declared extension or patch boundaries.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/JsonArray"
        },
        {
          "$ref": "#/$defs/JsonObject"
        }
      ]
    },
    "JsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/JsonValue"
      }
    },
    "JsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      }
    }
  }
}
