{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.nireco.dev/comet-integration/0.4-preview.2/schemas/integration.schema.json",
  "title": "Nireco–Comet Integration and Revision-bound Read Protocol",
  "description": "Trusted adapter protocol and Gate 1 revision-bound read service messages. Model-generated tool input is not represented by this schema.",
  "$ref": "#/$defs/CometIntegrationHandshakeRequest",
  "$defs": {
    "IntegrationCapability": {
      "enum": [
        "document.outline.read",
        "document.content.read",
        "document.search",
        "document.diagnostics.read",
        "academic.references.read",
        "academic.evidence.read",
        "academic.claims.read",
        "proposal.create",
        "proposal.edit",
        "proposal.validate",
        "proposal.rebase",
        "proposal.submit-review",
        "citation.propose",
        "evidence.propose"
      ]
    },
    "TransportFeature": {
      "enum": ["in-process", "worker", "ipc", "internal-rpc", "cursor-pagination", "idempotency"]
    },
    "CometIntegrationHandshakeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestedContractVersion",
        "cometBuildId",
        "adapterVersion",
        "workflowId",
        "requiredCapabilities",
        "requiredSemanticEdits",
        "requiredTransportFeatures"
      ],
      "properties": {
        "requestedContractVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "cometBuildId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "adapterVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "workflowId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "requiredCapabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntegrationCapability"
          },
          "uniqueItems": true
        },
        "requiredSemanticEdits": {
          "type": "array",
          "items": {
            "$ref": "semantic-edit.schema.json#/$defs/SemanticEditKind"
          },
          "uniqueItems": true
        },
        "requiredTransportFeatures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TransportFeature"
          },
          "uniqueItems": true
        }
      }
    },
    "CometIntegrationHandshakeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptedContractVersion",
        "nirecoBuildId",
        "documentFormatVersion",
        "schemaVersion",
        "transactionProtocolVersion",
        "proposalProtocolVersion",
        "semanticEditProtocolVersion",
        "supportedCapabilities",
        "supportedSemanticEdits",
        "limits",
        "featureFlags",
        "transportFeatures"
      ],
      "properties": {
        "acceptedContractVersion": {
          "const": "0.4-preview.1"
        },
        "nirecoBuildId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "documentFormatVersion": {
          "const": "1.0.0-preview.1"
        },
        "schemaVersion": {
          "const": "1.0.0-preview.1"
        },
        "transactionProtocolVersion": {
          "const": "0.4-preview.1"
        },
        "proposalProtocolVersion": {
          "const": "0.4-preview.1"
        },
        "semanticEditProtocolVersion": {
          "const": "0.4-preview.1"
        },
        "supportedCapabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntegrationCapability"
          },
          "uniqueItems": true
        },
        "supportedSemanticEdits": {
          "type": "array",
          "items": {
            "$ref": "semantic-edit.schema.json#/$defs/SemanticEditKind"
          },
          "uniqueItems": true
        },
        "limits": {
          "$ref": "#/$defs/ContractLimits"
        },
        "featureFlags": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][A-Za-z0-9]*$"
          },
          "additionalProperties": {
            "type": "boolean"
          },
          "description": "Intentional map exception: feature-flag keys are negotiated and namespaced by this private contract."
        },
        "transportFeatures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TransportFeature"
          },
          "uniqueItems": true
        }
      }
    },
    "ContractLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxRequestBytes",
        "maxResponseBytes",
        "maxPageItems",
        "maxChangedUtf16Units",
        "maxOperations",
        "maxNewReferences",
        "maxDeletedNodes",
        "maxMovedNodes",
        "sessionTtlSeconds",
        "cursorTtlSeconds"
      ],
      "properties": {
        "maxRequestBytes": {
          "type": "integer",
          "minimum": 1
        },
        "maxResponseBytes": {
          "type": "integer",
          "minimum": 1
        },
        "maxPageItems": {
          "type": "integer",
          "minimum": 1
        },
        "maxChangedUtf16Units": {
          "type": "integer",
          "minimum": 0
        },
        "maxOperations": {
          "type": "integer",
          "minimum": 1
        },
        "maxNewReferences": {
          "type": "integer",
          "minimum": 0
        },
        "maxDeletedNodes": {
          "type": "integer",
          "minimum": 0
        },
        "maxMovedNodes": {
          "type": "integer",
          "minimum": 0
        },
        "sessionTtlSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "cursorTtlSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "CometDocumentScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedSectionIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/NodeId"
          },
          "maxItems": 1000,
          "uniqueItems": true
        },
        "allowedNodeIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/NodeId"
          },
          "maxItems": 1000,
          "uniqueItems": true
        },
        "allowReadOutsideScopeForContext": {
          "type": "boolean"
        },
        "maxContextDistance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      },
      "description": "Each ID array is capped at 1000 entries. The combined allowedSectionIds plus allowedNodeIds count is also capped at 1000 as a runtime cross-field invariant. maxContextDistance is capped at 1000000 at every Session, service, and cursor boundary."
    },
    "CometIntegrationConstraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requireEvidenceForCitation",
        "requireVerifiedEvidence",
        "allowMetadataOnlyCitation",
        "allowDelete",
        "allowStructureMove"
      ],
      "properties": {
        "maxChangedUtf16Units": {
          "type": "integer",
          "minimum": 0
        },
        "maxOperations": {
          "type": "integer",
          "minimum": 1
        },
        "maxNewReferences": {
          "type": "integer",
          "minimum": 0
        },
        "maxDeletedNodes": {
          "type": "integer",
          "minimum": 0
        },
        "maxMovedNodes": {
          "type": "integer",
          "minimum": 0
        },
        "requireEvidenceForCitation": {
          "type": "boolean"
        },
        "requireVerifiedEvidence": {
          "type": "boolean"
        },
        "allowMetadataOnlyCitation": {
          "type": "boolean"
        },
        "allowDelete": {
          "type": "boolean"
        },
        "allowStructureMove": {
          "type": "boolean"
        }
      }
    },
    "OpenCometSessionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "target",
        "taskId",
        "traceId",
        "actor",
        "requestedCapabilities",
        "scope",
        "constraints",
        "policySnapshotId"
      ],
      "properties": {
        "contractVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "target": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "taskId": {
          "$ref": "common.schema.json#/$defs/TaskId"
        },
        "traceId": {
          "$ref": "common.schema.json#/$defs/TraceId"
        },
        "actor": {
          "$ref": "common.schema.json#/$defs/CometAgentActorRef"
        },
        "requestedCapabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntegrationCapability"
          },
          "uniqueItems": true
        },
        "scope": {
          "$ref": "#/$defs/CometDocumentScope"
        },
        "constraints": {
          "$ref": "#/$defs/CometIntegrationConstraints"
        },
        "policySnapshotId": {
          "$ref": "common.schema.json#/$defs/PolicySnapshotId"
        }
      }
    },
    "OpenCometSessionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractVersion",
        "sessionId",
        "target",
        "grantedCapabilities",
        "scope",
        "constraints",
        "limits",
        "capabilityGrantId",
        "expiresAt"
      ],
      "properties": {
        "contractVersion": {
          "const": "0.4-preview.1"
        },
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "target": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "grantedCapabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntegrationCapability"
          },
          "uniqueItems": true
        },
        "scope": {
          "$ref": "#/$defs/CometDocumentScope"
        },
        "constraints": {
          "$ref": "#/$defs/CometIntegrationConstraints"
        },
        "limits": {
          "$ref": "#/$defs/ContractLimits"
        },
        "capabilityGrantId": {
          "$ref": "common.schema.json#/$defs/CapabilityGrantId"
        },
        "expiresAt": {
          "$ref": "common.schema.json#/$defs/Rfc3339Timestamp"
        }
      }
    },
    "Gate1ReadService": {
      "enum": [
        "workspace.resolve_model",
        "document.get_head",
        "document.get_snapshot",
        "document.get_outline",
        "document.read_nodes",
        "document.read_node_neighborhood",
        "document.search",
        "document.get_changes_since",
        "document.get_diagnostics"
      ]
    },
    "RevisionBoundConsistency": {
      "enum": ["exact", "eventual"]
    },
    "RevisionBoundStatus": {
      "enum": ["current", "stale", "computing", "failed"]
    },
    "SuccessfulRevisionBoundStatus": {
      "enum": ["current", "stale"]
    },
    "ReadCursor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Opaque, unpadded canonical base64url cursor. The authenticated server-side binding covers the Session, Revision, granted Scope, service and canonical query hash; the wire value contains no raw IDs, Scope or storage key."
    },
    "ReadMaxResults": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "RevisionBoundReadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "basedOnRevisionId", "consistency", "status"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "$ref": "#/$defs/RevisionBoundConsistency"
        },
        "status": {
          "$ref": "#/$defs/RevisionBoundStatus"
        }
      }
    },
    "ReadPageRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      },
      "description": "A requested maxResults is additionally capped by the negotiated Session maxPageItems."
    },
    "PageResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "basedOnRevisionId",
        "consistency",
        "status",
        "items",
        "truncated",
        "approximateBytes"
      ],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "$ref": "#/$defs/RevisionBoundConsistency"
        },
        "status": {
          "$ref": "#/$defs/SuccessfulRevisionBoundStatus"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PageItem"
          },
          "maxItems": 1000
        },
        "nextCursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "truncated": {
          "type": "boolean"
        },
        "approximateBytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["truncated"],
            "properties": {
              "truncated": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "nextCursor": {
                "$ref": "#/$defs/ReadCursor"
              }
            },
            "required": ["nextCursor"]
          },
          "else": {
            "properties": {
              "nextCursor": false
            }
          }
        }
      ],
      "description": "No silent truncation: truncated=true requires a continuation cursor and truncated=false forbids one. approximateBytes is capped at runtime by the negotiated maxResponseBytes."
    },
    "PageItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/OutlineItem"
        },
        {
          "$ref": "#/$defs/ReadableDocumentNode"
        },
        {
          "$ref": "#/$defs/DocumentSearchHit"
        },
        {
          "$ref": "#/$defs/DocumentRevisionChange"
        },
        {
          "$ref": "diagnostic.schema.json#/$defs/Diagnostic"
        }
      ]
    },
    "ResolveModelRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        }
      }
    },
    "ResolveModelResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "basedOnRevisionId", "consistency", "status"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "const": "exact"
        },
        "status": {
          "$ref": "#/$defs/SuccessfulRevisionBoundStatus"
        }
      }
    },
    "GetDocumentHeadRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        }
      }
    },
    "GetDocumentHeadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "basedOnRevisionId", "consistency", "status", "headRevisionId"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "const": "exact"
        },
        "status": {
          "const": "current"
        },
        "headRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        }
      }
    },
    "GetDocumentSnapshotRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        }
      }
    },
    "GetDocumentSnapshotResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "basedOnRevisionId", "consistency", "status", "snapshot"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "const": "exact"
        },
        "status": {
          "$ref": "#/$defs/SuccessfulRevisionBoundStatus"
        },
        "snapshot": {
          "$ref": "manuscript.schema.json#/$defs/DocumentSnapshot"
        }
      }
    },
    "OutlineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "nodeType", "depth", "title", "authorizedChildCount", "nodeHash"],
      "properties": {
        "nodeId": {
          "$ref": "common.schema.json#/$defs/NodeId"
        },
        "parentNodeId": {
          "$ref": "common.schema.json#/$defs/NodeId",
          "description": "Present only when the parent itself is authorized by the granted Scope."
        },
        "nodeType": {
          "$ref": "#/$defs/NodeKind"
        },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        },
        "title": {
          "type": "string",
          "maxLength": 2048
        },
        "authorizedChildCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991,
          "description": "Counts only children authorized by the granted Scope."
        },
        "nodeHash": {
          "$ref": "common.schema.json#/$defs/ContentHash"
        }
      }
    },
    "NodeKind": {
      "enum": [
        "bibliographyPlaceholder",
        "blockQuote",
        "body",
        "citation",
        "codeBlock",
        "crossReference",
        "displayEquation",
        "figure",
        "figureAsset",
        "figureCaption",
        "footnote",
        "footnoteReference",
        "frontMatter",
        "hardBreak",
        "heading",
        "horizontalRule",
        "inlineEquation",
        "list",
        "listItem",
        "manuscript",
        "paragraph",
        "section",
        "table",
        "tableCaption",
        "tableCell",
        "tableRow",
        "text"
      ]
    },
    "GetDocumentOutlineRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "GetDocumentOutlineResult": {
      "allOf": [
        {
          "$ref": "#/$defs/PageResult"
        },
        {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/OutlineItem"
              },
              "maxItems": 1000
            }
          }
        }
      ]
    },
    "ReadableDocumentNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "nodeType", "childIds"],
      "properties": {
        "nodeId": {
          "$ref": "common.schema.json#/$defs/NodeId"
        },
        "nodeType": {
          "$ref": "#/$defs/NodeKind"
        },
        "attrs": {
          "$ref": "common.schema.json#/$defs/JsonObject",
          "description": "Exact canonical attributes of an attributed source node; never model-supplied attributes."
        },
        "text": {
          "type": "string"
        },
        "marks": {
          "type": "array",
          "items": {
            "$ref": "manuscript.schema.json#/$defs/Mark"
          },
          "maxItems": 8,
          "uniqueItems": true
        },
        "childIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/NodeId"
          },
          "uniqueItems": true,
          "description": "Non-recursive child references filtered to IDs authorized by the granted Scope."
        },
        "nodeHash": {
          "$ref": "common.schema.json#/$defs/ContentHash",
          "description": "Present only when the complete canonical subtree covered by the hash is authorized (document-wide or allowed-Section context), or for an exact authorized Text leaf. It is omitted from partial exact non-Text projections to avoid a hidden-subtree hash oracle."
        },
        "parentNodeId": {
          "$ref": "common.schema.json#/$defs/NodeId",
          "description": "Present only when the parent itself is authorized by the granted Scope."
        },
        "authorizedChildIndex": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991,
          "description": "Index among authorized siblings only; never exposes the position of hidden siblings."
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["nodeType"],
            "properties": {
              "nodeType": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": ["text", "marks"],
            "properties": {
              "text": {
                "type": "string"
              },
              "marks": {
                "type": "array",
                "items": {
                  "$ref": "manuscript.schema.json#/$defs/Mark"
                },
                "maxItems": 8,
                "uniqueItems": true
              },
              "childIds": {
                "type": "array",
                "maxItems": 0
              },
              "attrs": false
            }
          },
          "else": {
            "required": ["attrs"],
            "properties": {
              "attrs": {
                "$ref": "common.schema.json#/$defs/JsonObject"
              },
              "text": false,
              "marks": false
            }
          }
        }
      ],
      "description": "A scope-filtered shallow projection. It cannot recursively embed DocumentNode children, expose DOM positions, or expose a hash of hidden subtree content."
    },
    "ReadDocumentNodesRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document", "nodeIds"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "nodeIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/NodeId"
          },
          "minItems": 1,
          "maxItems": 1000,
          "uniqueItems": true
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "ReadDocumentNodesResult": {
      "allOf": [
        {
          "$ref": "#/$defs/PageResult"
        },
        {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ReadableDocumentNode"
              },
              "maxItems": 1000
            }
          }
        }
      ]
    },
    "ReadDocumentNodeNeighborhoodRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document", "nodeId", "beforeBlocks", "afterBlocks"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "nodeId": {
          "$ref": "common.schema.json#/$defs/NodeId"
        },
        "beforeBlocks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "afterBlocks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "ReadDocumentNodeNeighborhoodResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "basedOnRevisionId",
        "consistency",
        "status",
        "items",
        "truncated",
        "approximateBytes",
        "centerNodeId"
      ],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "$ref": "#/$defs/RevisionBoundConsistency"
        },
        "status": {
          "$ref": "#/$defs/SuccessfulRevisionBoundStatus"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReadableDocumentNode"
          },
          "maxItems": 201
        },
        "nextCursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "truncated": {
          "type": "boolean"
        },
        "approximateBytes": {
          "type": "integer",
          "minimum": 0
        },
        "centerNodeId": {
          "$ref": "common.schema.json#/$defs/NodeId"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["truncated"],
            "properties": {
              "truncated": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "nextCursor": {
                "$ref": "#/$defs/ReadCursor"
              }
            },
            "required": ["nextCursor"]
          },
          "else": {
            "properties": {
              "nextCursor": false
            }
          }
        }
      ]
    },
    "DocumentSearchKind": {
      "enum": ["text", "citation", "claim", "heading"]
    },
    "DocumentSearchMatch": {
      "enum": ["exact", "prefix", "substring", "token"]
    },
    "DocumentSearchTarget": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "nodeId"],
          "properties": {
            "kind": {
              "const": "node"
            },
            "nodeId": {
              "$ref": "common.schema.json#/$defs/NodeId"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "entityId"],
          "properties": {
            "kind": {
              "const": "academic-entity"
            },
            "entityId": {
              "$ref": "common.schema.json#/$defs/EntityId"
            }
          }
        }
      ],
      "description": "A stable semantic target. DOM nodes and raw DOM offsets are not part of the contract."
    },
    "DocumentSearchHit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target", "match", "snippet"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/DocumentSearchKind"
        },
        "target": {
          "$ref": "#/$defs/DocumentSearchTarget"
        },
        "match": {
          "$ref": "#/$defs/DocumentSearchMatch"
        },
        "snippet": {
          "type": "string",
          "maxLength": 4096,
          "description": "Scope-authorized text only. It never carries a DOM offset."
        }
      }
    },
    "SearchDocumentRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document", "query"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sectionIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/NodeId"
          },
          "maxItems": 256,
          "uniqueItems": true,
          "description": "An optional narrowing intersected with the granted Scope; it can never broaden the Session grant."
        },
        "kinds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DocumentSearchKind"
          },
          "maxItems": 4,
          "uniqueItems": true
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "SearchDocumentResult": {
      "allOf": [
        {
          "$ref": "#/$defs/PageResult"
        },
        {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/DocumentSearchHit"
              },
              "maxItems": 1000
            }
          }
        }
      ]
    },
    "DocumentRevisionChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision"],
      "properties": {
        "revision": {
          "$ref": "revision.schema.json#/$defs/Revision"
        }
      }
    },
    "GetDocumentChangesSinceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document", "sinceRevisionId"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "sinceRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "GetDocumentChangesSinceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "basedOnRevisionId",
        "consistency",
        "status",
        "items",
        "truncated",
        "approximateBytes",
        "fromRevisionId"
      ],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "basedOnRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "consistency": {
          "$ref": "#/$defs/RevisionBoundConsistency"
        },
        "status": {
          "$ref": "#/$defs/SuccessfulRevisionBoundStatus"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DocumentRevisionChange"
          },
          "maxItems": 1000
        },
        "nextCursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "truncated": {
          "type": "boolean"
        },
        "approximateBytes": {
          "type": "integer",
          "minimum": 0
        },
        "fromRevisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["truncated"],
            "properties": {
              "truncated": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "nextCursor": {
                "$ref": "#/$defs/ReadCursor"
              }
            },
            "required": ["nextCursor"]
          },
          "else": {
            "properties": {
              "nextCursor": false
            }
          }
        }
      ]
    },
    "GetDocumentDiagnosticsRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "severities": {
          "type": "array",
          "items": {
            "enum": ["info", "warning", "error"]
          },
          "maxItems": 3,
          "uniqueItems": true
        },
        "codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$",
            "maxLength": 128
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "cursor": {
          "$ref": "#/$defs/ReadCursor"
        },
        "maxResults": {
          "$ref": "#/$defs/ReadMaxResults"
        }
      }
    },
    "GetDocumentDiagnosticsResult": {
      "allOf": [
        {
          "$ref": "#/$defs/PageResult"
        },
        {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "diagnostic.schema.json#/$defs/Diagnostic"
              },
              "maxItems": 1000
            }
          }
        }
      ]
    },
    "GetSnapshotRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "document"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        }
      }
    },
    "GetSnapshotResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "snapshot"],
      "properties": {
        "document": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "snapshot": {
          "$ref": "manuscript.schema.json#/$defs/DocumentSnapshot"
        }
      }
    },
    "CreateProposalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "target", "idempotencyKey"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "target": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentRef"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "CreateProposalResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposal"],
      "properties": {
        "proposal": {
          "$ref": "proposal.schema.json#/$defs/Proposal"
        }
      }
    },
    "StageSemanticEditsRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "proposal", "semanticEdits", "idempotencyKey"],
      "properties": {
        "sessionId": {
          "$ref": "common.schema.json#/$defs/SessionId"
        },
        "proposal": {
          "$ref": "proposal.schema.json#/$defs/ProposalRef"
        },
        "semanticEdits": {
          "type": "array",
          "items": {
            "$ref": "semantic-edit.schema.json#/$defs/SemanticEdit"
          },
          "minItems": 1
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "StageSemanticEditsResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposal"],
      "properties": {
        "proposal": {
          "$ref": "proposal.schema.json#/$defs/Proposal"
        }
      }
    }
  }
}
