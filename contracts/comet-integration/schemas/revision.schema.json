{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.nireco.dev/comet-integration/0.4-preview.1/schemas/revision.schema.json",
  "title": "Nireco Linear Revision Protocol",
  "description": "Immutable, single-parent mainline revision identity and durability state.",
  "$ref": "#/$defs/Revision",
  "$defs": {
    "DurabilityLevel": {
      "enum": ["memory", "wal", "snapshot"],
      "description": "Highest acknowledged durability level. State advances monotonically."
    },
    "AuthorityMode": {
      "enum": ["read-write", "read-only", "recovery-required"]
    },
    "Revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "uri",
        "parentRevisionId",
        "transactionId",
        "sequence",
        "documentHash",
        "actor",
        "createdAt",
        "durability"
      ],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "uri": {
          "$ref": "resource-ref.schema.json#/$defs/DocumentUri"
        },
        "parentRevisionId": {
          "oneOf": [
            {
              "$ref": "common.schema.json#/$defs/RevisionId"
            },
            {
              "type": "null"
            }
          ]
        },
        "transactionId": {
          "$ref": "common.schema.json#/$defs/TransactionId"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "documentHash": {
          "$ref": "common.schema.json#/$defs/ContentHash"
        },
        "actor": {
          "$ref": "common.schema.json#/$defs/ActorRef"
        },
        "createdAt": {
          "$ref": "common.schema.json#/$defs/Rfc3339Timestamp"
        },
        "durability": {
          "$ref": "#/$defs/DurabilityLevel"
        }
      }
    },
    "DurabilityAcknowledgement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revisionId", "achievedDurability", "authorityMode"],
      "properties": {
        "revisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "achievedDurability": {
          "$ref": "#/$defs/DurabilityLevel"
        },
        "authorityMode": {
          "$ref": "#/$defs/AuthorityMode"
        }
      }
    },
    "CommitResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revisionId", "snapshot", "transactionHash", "achievedDurability"],
      "properties": {
        "revisionId": {
          "$ref": "common.schema.json#/$defs/RevisionId"
        },
        "snapshot": {
          "$ref": "manuscript.schema.json#/$defs/DocumentSnapshot"
        },
        "transactionHash": {
          "$ref": "common.schema.json#/$defs/ContentHash"
        },
        "achievedDurability": {
          "const": "memory",
          "description": "apply() acknowledges only the in-memory commit; callers use whenDurable() for WAL or Snapshot."
        }
      }
    }
  }
}
