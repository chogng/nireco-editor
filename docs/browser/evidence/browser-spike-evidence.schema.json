{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.nireco.dev/browser-spike/evidence-v2.schema.json",
  "title": "Nireco Gate 0 browser spike evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidenceVersion", "capture", "run"],
  "properties": {
    "evidenceVersion": {
      "const": 2
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["browser", "screenshot", "tool"],
      "properties": {
        "browser": {
          "enum": ["chrome", "webkit"]
        },
        "screenshot": {
          "$ref": "#/$defs/screenshot"
        },
        "tool": {
          "const": "@playwright/cli via Codex wrapper"
        }
      }
    },
    "run": {
      "$ref": "#/$defs/runEvidence"
    }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beforeInputEvent",
        "clipboardEvent",
        "compositionEvent",
        "dataTransfer",
        "mutationObserver",
        "selection"
      ],
      "properties": {
        "beforeInputEvent": {
          "type": "boolean"
        },
        "clipboardEvent": {
          "type": "boolean"
        },
        "compositionEvent": {
          "type": "boolean"
        },
        "dataTransfer": {
          "type": "boolean"
        },
        "mutationObserver": {
          "type": "boolean"
        },
        "selection": {
          "type": "boolean"
        }
      }
    },
    "console": {
      "type": "object",
      "additionalProperties": false,
      "required": ["errors", "warnings"],
      "properties": {
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "platform", "userAgent", "version"],
      "properties": {
        "family": {
          "enum": ["Chromium", "WebKit"]
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "userAgent": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}$"
        }
      }
    },
    "runEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilities", "console", "engine", "scenarioResults", "scope", "summary"],
      "properties": {
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "console": {
          "$ref": "#/$defs/console"
        },
        "engine": {
          "$ref": "#/$defs/engine"
        },
        "scenarioResults": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/scenarioResult"
          }
        },
        "scope": {
          "const": "isolated-gate-0-spike"
        },
        "summary": {
          "$ref": "#/$defs/summary"
        }
      }
    },
    "scenarioResult": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "observed", "status"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "observed": {
              "type": "object"
            },
            "status": {
              "const": "pass"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["error", "id", "status"],
          "properties": {
            "error": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 1
                },
                "message": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "const": "fail"
            }
          }
        }
      ]
    },
    "screenshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^docs/browser/evidence/screenshots/[a-z0-9.-]+\\.png$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failed", "passed", "total"],
      "properties": {
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "const": 7
        }
      }
    }
  }
}
